# YNLED LiveView API — Environment Variables
# Copy to .env and fill in values before starting the server.
# Never commit .env to git.

# Generate with: openssl rand -hex 32
API_TOKEN=your-secret-token-here

# Port the Express server listens on (nginx proxies /api/ → this port)
PORT=3001

# SQLite database file path
DB_PATH=/opt/ynled/db/liveview.db

# VPS domain (used in camera EHome config responses)
VPS_DOMAIN=stream.ynled.com
