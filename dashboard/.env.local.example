# YNLED LiveView Dashboard — Environment Variables
# Copy to .env.local for local dev. Set these in Vercel project settings for production.

# --- VPS self-hosted setup ---
# Internal URL from Next.js server to Express (never exposed to browser)
# Defaults to http://127.0.0.1:3001 if not set
API_INTERNAL_URL=http://127.0.0.1:3001

# --- Public/Vercel setup ---
# Public URL used when building for Vercel or when API_INTERNAL_URL is not set
# Use your domain once DNS is configured
NEXT_PUBLIC_API_URL=https://stream.ynled.com

# Secret token for VPS API — NEVER use NEXT_PUBLIC_ prefix for this
# This value stays server-side only (used in /app/api/** proxy routes)
API_TOKEN=your-secret-token-here
